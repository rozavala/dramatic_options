# dramatic_options environment — copy to .env and fill in. (.env is gitignored — line 9 of
# .gitignore.) ALL secrets are read from .env ONLY: config.json holds no keys, and nothing is
# hardcoded in source. config_loader.load_config() calls load_dotenv() then os.getenv() for each
# of the variables below; provider keys are passed explicitly to each SDK client.
#
# Minimum to run:
#   • offline demo (no creds at all):  python -m dramatic_options.orchestrator --demo   (uses the FakeRouter)
#   • paper trading:                   the Alpaca keys + the safety gates
#   • the council (T2, enabled):       the three provider keys for the default role map (below)

# ── Alpaca (paper-first) — REQUIRED for any non-demo run ────────────────────
ALPACA_API_KEY=your_alpaca_paper_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret
# true = paper endpoint (default). Never set false without the live gates below.
ALPACA_PAPER=true

# ── Safety gates (all three required for live; see CLAUDE.md / SPEC §13) ────
PAPER=true
LIVE_TRADING_ENABLED=false
DRY_RUN=true

# ── Forward loop (T2.5): does THIS env run the scheduled systemd timers? ────
# DISTINCT from the live triple-gate above. DEV (paper) = true → it trades the loop;
# PROD (real-money) stays false (installed-but-inert) until T4. Default false (fail-safe).
# The deploy enables the L1/L2 timers only where this is true; the verify gate requires the
# Alpaca + LLM + Pushover keys below when this is true. DEV pairs FORWARD_ENABLED=true with
# DRY_RUN=false (real two-sided paper submit).
FORWARD_ENABLED=false

# ── Data feed: 'indicative' (free) for build/paper, 'opra' (paid) before live
DATA_FEED=indicative

# ── EDGAR (Phase 1): SEC requires a User-Agent that identifies you with contact.
# Keyless API; this UA is sent on every data.sec.gov / efts.sec.gov request.
EDGAR_USER_AGENT=dramatic-options your_email@example.com

# ── Council LLM providers (T2) ─────────────────────────────────────────────
# The heterogeneous council routes each role to a DISTINCT provider (config.json:
# council.roles). DEFAULT role map → the three keys marked REQUIRED below are needed:
#     proposer  → Gemini      (GEMINI_API_KEY)
#     adversary → xAI / Grok  (XAI_API_KEY)
#     strategist→ Anthropic   (ANTHROPIC_API_KEY)
# A missing key for a MAPPED provider on an ENABLED council fails closed (0 entries that
# cycle, RouterError logged). Set council.enabled=false in config.json to skip the council
# entirely (T1 hand-seeded loop), and `dramatic_options.orchestrator --demo` needs none of these.
GEMINI_API_KEY=your_gemini_key          # REQUIRED (default proposer)
XAI_API_KEY=your_xai_key                # REQUIRED (default adversary)
ANTHROPIC_API_KEY=your_anthropic_key    # REQUIRED (default strategist)
# Optional — only needed if you remap a council role to these providers (config.json:
# council.roles). OPENAI also serves xAI/Perplexity transport via base_url.
# OPENAI_API_KEY=your_openai_key
# PERPLEXITY_API_KEY=your_perplexity_key

# ── Kill switch (optional): halts the trade cycle when set (also: `touch KILL`). ──
# KILL=1

# ── Pushover paging (T2.5): operational alerts from the scheduled loop ──────
# Used by notify.py for (a) the systemd OnFailure hook on a NON-zero exit (no creds, broker
# unreachable, a TimeoutStartSec-killed hang) and (b) in-app pages for the soft exit-0
# conditions OnFailure can't catch (kill-rule trip / fail-closed council / cost-cap trip).
# REQUIRED when FORWARD_ENABLED=true (the verify gate asserts them). Unset → notify.py no-ops.
PUSHOVER_API_TOKEN=your_pushover_app_token
PUSHOVER_USER_KEY=your_pushover_user_key
