# dramatic_options environment — copy to .env and fill in. (.env is gitignored.)
# Phase 0 needs only the Alpaca paper keys + the safety gates.

# ── Alpaca (paper-first) ───────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_paper_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret
# true = paper endpoint (default). Never set false without the live gates below.
ALPACA_PAPER=true

# ── Safety gates (all three required for live; see CLAUDE.md / SPEC §13) ────
PAPER=true
LIVE_TRADING_ENABLED=false
DRY_RUN=true

# ── Data feed: 'indicative' (free) for build/paper, 'opra' (paid) before live
DATA_FEED=indicative

# ── Later phases (leave commented until needed) ────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# PERPLEXITY_API_KEY=
# EDGAR_USER_AGENT=your_name your_email   # SEC requires a UA string
# PUSHOVER_API_TOKEN=
# PUSHOVER_USER_KEY=
