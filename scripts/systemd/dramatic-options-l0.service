# Dramatic Options — L0 weekly sentinel discovery scan (motion/structural funnel → framer → sentinels).
# TEMPLATE: deploy.sh renders __REPO_ROOT__ / __USER__ / __GROUP__ at install time so the same
# file is correct on DEV (rodrigo) and PROD (console). Never loaded raw.
#
# Type=oneshot fired by dramatic-options-l0.timer (Sun 08:00 ET, weekly). Runs ONE discovery scan
# (`orchestrator.py --discover`): it surfaces NEW candidates into the sentinel store for the next
# L1 council to judge — it NEVER trades, submits, or runs the monitor (the hard seam, PREREG §2).
# FORWARD_ENABLED + discovery.enabled gate whether the scan runs; an inert env / disabled
# discovery / a tripped kill rule scans nothing and spends nothing (orchestrator.run_discover).
[Unit]
Description=Dramatic Options L0 weekly sentinel discovery scan (funnel → framer → sentinels)
After=network-online.target
Wants=network-online.target
# Hard, non-zero exits (no creds, a TimeoutStartSec kill) page via Pushover. The framer's SOFT
# fail-closed paths (over-budget / provider error → frame nothing, exit 0) page in-app from the
# orchestrator where they matter; a clean no-op scan does not page.
OnFailure=dramatic-options-notify@%n.service

[Service]
Type=oneshot
User=__USER__
Group=__GROUP__
WorkingDirectory=__REPO_ROOT__
EnvironmentFile=__REPO_ROOT__/.env
Environment=PYTHONUNBUFFERED=1
# Hang ceiling (PR3) — DERIVED from the §C cold-cache measurement (2026-06-02), not guessed:
#   • a healthy cold scan measured ~11s wall-clock ($0.0019, 8 gemini-3.1-flash-lite framer calls);
#   • the only unbounded cost is the <=scan_top_k (8) SEQUENTIAL framer calls, each bounded by the
#     router's timeout_s(60) x (max_retries+1)(3) + backoff ~= 183s -> an 8-call hard ceiling ~= 1464s;
#   • a realistic slow-but-HEALTHY scan (all 8 calls at the full 60s SDK timeout, no retries) ~= 540s.
# 900s clears the realistic-healthy ceiling with margin yet SIGTERMs (-> OnFailure -> page) a broadly
# DEGRADED-provider scan (~1460s) rather than letting it grind — the "fail loud" posture (cf. L2).
# Lower than L1's 1800 because L0 has no 3-role council debate, no entries, no broker reconcile.
# Bump if it ever pages on a legitimately slow week.
TimeoutStartSec=900
ExecStart=__REPO_ROOT__/venv/bin/python -u orchestrator.py --discover
